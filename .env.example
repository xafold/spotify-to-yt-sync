# ──────────────────────────────────────────────────────────────────────────────
# Spotify Credentials
# Get these from https://developer.spotify.com/dashboard
# ──────────────────────────────────────────────────────────────────────────────
SPOTIPY_CLIENT_ID=your_spotify_client_id
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ──────────────────────────────────────────────────────────────────────────────
# Spotify Playlist (use NAME *or* ID — name takes priority)
#
# Set SPOTIFY_PLAYLIST_NAME to "Liked Songs" to sync your Liked Songs library.
# ──────────────────────────────────────────────────────────────────────────────
SPOTIFY_PLAYLIST_NAME=Liked Songs
# SPOTIFY_PLAYLIST_ID=your_spotify_playlist_id

# ──────────────────────────────────────────────────────────────────────────────
# YouTube OAuth Credentials
# Create a project at https://console.cloud.google.com/
#   1. Enable the YouTube Data API v3
#   2. Create an OAuth 2.0 Client ID (Desktop app)
#   3. Download the JSON and save it as client_secret.json in this directory
# ──────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────────────────
# YouTube Playlist (use NAME *or* ID — name takes priority)
#
# If the playlist does not exist it will be created automatically.
# Defaults to the same name as the Spotify playlist if left blank.
# ──────────────────────────────────────────────────────────────────────────────
YOUTUBE_PLAYLIST_NAME=Liked Songs
# YOUTUBE_PLAYLIST_ID=your_youtube_playlist_id

# ──────────────────────────────────────────────────────────────────────────────
# Sync Configuration
# ──────────────────────────────────────────────────────────────────────────────

# How often (in seconds) to check for new songs (default: 300 = 5 minutes)
SYNC_INTERVAL_SECONDS=300
