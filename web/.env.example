# =============================================================================
# 🎵 Spotify → YouTube Sync — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Vercel deployment, add these in:
#   Vercel Dashboard → Your Project → Settings → Environment Variables
# =============================================================================


# -----------------------------------------------------------------------------
# 🔐 SESSION SECRET
# -----------------------------------------------------------------------------
# A random secret string used to encrypt session cookies.
# Generate one with: openssl rand -base64 32
# Or visit: https://generate-secret.vercel.app/32
# -----------------------------------------------------------------------------
SESSION_SECRET=replace_me_with_a_random_32_plus_character_string


# -----------------------------------------------------------------------------
# 🌐 APP URL
# -----------------------------------------------------------------------------
# The base URL of your deployed app (no trailing slash).
# For local development: http://localhost:3000
# For Vercel: https://your-project-name.vercel.app
# -----------------------------------------------------------------------------
APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# 🎵 SPOTIFY CREDENTIALS
# -----------------------------------------------------------------------------
# How to get these:
#   1. Go to https://developer.spotify.com/dashboard
#   2. Log in and click "Create App"
#   3. Fill in App name & description, then click "Save"
#   4. In your app settings, add this Redirect URI:
#        http://localhost:3000/api/auth/spotify/callback   ← for local dev
#        https://your-app.vercel.app/api/auth/spotify/callback  ← for Vercel
#   5. Copy your Client ID and Client Secret below
# -----------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here


# -----------------------------------------------------------------------------
# 📺 GOOGLE / YOUTUBE CREDENTIALS
# -----------------------------------------------------------------------------
# How to get these:
#   1. Go to https://console.cloud.google.com/
#   2. Create a new project (or select an existing one)
#   3. Go to "APIs & Services" → "Library"
#   4. Search for "YouTube Data API v3" and click "Enable"
#   5. Go to "APIs & Services" → "Credentials"
#   6. Click "+ Create Credentials" → "OAuth 2.0 Client IDs"
#   7. Set Application type to "Web application"
#   8. Under "Authorized redirect URIs", add:
#        http://localhost:3000/api/auth/youtube/callback   ← for local dev
#        https://your-app.vercel.app/api/auth/youtube/callback  ← for Vercel
#   9. Click "Create" and copy your Client ID and Client Secret below
#
# NOTE: You may also need to configure the OAuth Consent Screen:
#   - Go to "APIs & Services" → "OAuth consent screen"
#   - Choose "External" user type
#   - Fill in app name, support email, and developer contact
#   - Add the scope: https://www.googleapis.com/auth/youtube
#   - Add your Google account as a test user (while in Testing mode)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here


# -----------------------------------------------------------------------------
# 🗄️ VERCEL KV (Redis) — for sync state persistence
# -----------------------------------------------------------------------------
# Vercel KV stores the list of already-synced Spotify track IDs so the app
# never adds duplicates to your YouTube playlist.
#
# How to set up (only needed for Vercel deployment):
#   1. Go to your Vercel project dashboard
#   2. Click the "Storage" tab
#   3. Click "Create Database" → choose "KV"
#   4. Follow the prompts — Vercel will auto-inject the variables below
#
# For local development, the app uses in-memory storage as a fallback
# (state is lost on restart, but fine for testing).
#
# These variables are injected automatically when you connect Vercel KV.
# You do NOT need to set them manually on Vercel.
# -----------------------------------------------------------------------------
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=


# -----------------------------------------------------------------------------
# ⏱️  OPTIONAL: Default sync interval (in seconds)
# -----------------------------------------------------------------------------
# How often the app checks for new songs when auto-sync is enabled.
# Default: 300 (5 minutes). Minimum recommended: 60.
# Note: Vercel Cron Jobs run at most once per minute on the free plan.
# -----------------------------------------------------------------------------
SYNC_INTERVAL_SECONDS=300
